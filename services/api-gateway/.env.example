APP_NAME="ANETI Matching API Gateway"
APP_ENV=local
APP_DEBUG=true

HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

CV_STORAGE_PROVIDER=AZURE_BLOB
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
CV_STORAGE_LOCAL_DIR=storage/cv-files
CV_STORAGE_CONTAINER=cv-files
CV_MAX_SIZE_MB=10

PARSING_SERVICE_URL=http://localhost:8001
PARSING_SERVICE_TIMEOUT_SECONDS=120
MATCHING_SERVICE_URL=http://localhost:8002
SEARCH_SERVICE_URL=http://localhost:8003
SEARCH_SERVICE_TIMEOUT_SECONDS=120
SEARCH_SERVICE_API_KEY=changeme
INTERNAL_API_KEY=dev_internal_api_key_change_me
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EVENTS_TOPIC=cv.events

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
