+def _normalize_token(value: Any) -> str:
+    if value is None:
+        return ""
+    return re.sub(r"\s+", " ", str(value).strip().lower())
+
+
+def _split_full_name(full_name: Any) -> tuple[str | None, str | None]:
+    text_value = _clean_text(full_name)
+    if not text_value:
+        return None, None
+
+    parts = [part for part in re.split(r"\s+", text_value) if part]
+    if not parts:
+        return None, None
+    if len(parts) == 1:
+        return parts[0], None
+    return parts[0], " ".join(parts[1:])
+
+
+def _find_country_by_iso2(db: Session, iso2: str | None) -> dict[str, Any] | None:
+    if not iso2:
+        return None
+    row = _fetch_one(
+        db,
+        """
+        SELECT
+            id::text AS id,
+            iso2::text AS iso2,
+            iso3::text AS iso3,
+            COALESCE(name_fr, name_en, iso2) AS label
+        FROM geo.country
+        WHERE upper(iso2) = upper(:iso2)
+        LIMIT 1;
+        """,
+        {"iso2": iso2},
+    )
+    return dict(row) if row else {"id": None, "iso2": iso2.upper(), "iso3": None, "label": iso2.upper()}
+
+
+def _lightweight_normalize_location(db: Session, raw_location: Any) -> dict[str, Any]:
+    """Fallback API-side normalizer used only when the parsing snapshot has no normalized location.
+
+    The authoritative normalizer remains parsing-service. This fallback prevents dry-run/apply
+    from losing an obvious foreign country such as US/FR/CA on older snapshots.
+    """
+    raw = _clean_text(raw_location)
+    if not raw:
+        return {}
+
+    normalized = _normalize_token(raw.replace("–", ",").replace("|", ",").replace("/", ","))
+    parts_raw = [part.strip() for part in re.split(r",|;", raw) if part.strip()]
+    parts_norm = [_normalize_token(part) for part in parts_raw]
+
+    matched_iso2: str | None = None
+    for part in parts_norm:
+        if part in _COUNTRY_ALIASES:
+            matched_iso2 = _COUNTRY_ALIASES[part]
+            break
+
+    # Very common international CV format: "Los Angeles, CA 90001".
+    state_match = re.search(r"\b([A-Z]{2})\s+\d{5}(?:-\d{4})?\b", raw)
+    if not matched_iso2 and state_match and state_match.group(1).upper() in _US_STATE_CODES:
+        matched_iso2 = "US"
+
+    country = _find_country_by_iso2(db, matched_iso2) if matched_iso2 else None
+    country_tokens = {token for token, iso2 in _COUNTRY_ALIASES.items() if iso2 == matched_iso2}
+
+    non_country_parts: list[str] = []
+    for original, part in zip(parts_raw, parts_norm, strict=False):
+        if part in country_tokens:
+            continue
+        non_country_parts.append(original)
+
+    city_raw = None
+    region_raw = None
+    if matched_iso2 == "US":
+        # Prefer the part before "CA 90001" as city, and extract state code as region.
+        for idx, part in enumerate(non_country_parts):
+            state_zip = re.search(r"\b([A-Z]{2})\s+\d{5}(?:-\d{4})?\b", part)
+            if state_zip:
+                region_raw = state_zip.group(1).upper()
+                if idx > 0:
+                    city_raw = non_country_parts[idx - 1]
+                break
+        if not city_raw and len(non_country_parts) >= 2:
+            city_raw = non_country_parts[-2]
+    else:
+        city_raw = non_country_parts[0] if non_country_parts else None
+        region_raw = non_country_parts[1] if len(non_country_parts) > 1 else None
+
+    status = "MATCHED_FOREIGN_COUNTRY" if matched_iso2 and matched_iso2 != "TN" else "MATCHED_COUNTRY" if matched_iso2 else "NOT_NORMALIZED"
+
+    return {
+        "raw_location": raw,
+        "normalized_location": normalized,
+        "location_parts": parts_norm,
+        "display_location": ", ".join(part for part in [city_raw, region_raw, country.get("label") if country else None] if part),
+        "status": status,
+        "country": country.get("label") if country else None,
+        "country_ref": country,
+        "country_id": country.get("id") if country else None,
+        "country_iso2": country.get("iso2") if country else matched_iso2,
+        "governorate": None,
+        "delegation": None,
+        "city_raw": city_raw,
+        "region_raw": region_raw,
+        "is_foreign": bool(matched_iso2 and matched_iso2 != "TN"),
+        "confidence": 0.82 if matched_iso2 else 0.0,
+        "source": "api_gateway_lightweight_location_normalizer",
+    }
+
+
+def _is_probable_profile_skill_label(label: Any) -> bool:
+    text_value = _clean_text(label)
+    if not text_value:
+        return False
+    if len(text_value) < 2 or len(text_value) > 80:
+        return False
+    # Reject fragments produced by PDF/statistical text extraction, e.g. "totaling nearly 300".
+    if any(pattern.search(text_value) for pattern in _NOISE_SKILL_PATTERNS):
+        return False
+    digit_count = sum(ch.isdigit() for ch in text_value)
+    if digit_count and digit_count / max(len(text_value), 1) > 0.15:
+        return False
+    return True
+
+
+def _looks_like_wrong_bachelor_to_bac_mapping(raw_degree: Any, diploma_label: Any, diploma_code: Any) -> bool:
+    raw = _normalize_token(raw_degree)
+    label = _normalize_token(diploma_label)
+    code = _normalize_token(diploma_code)
+    if not raw:
+        return False
+    if "bachelor" not in raw and "licence" not in raw and "master" not in raw:
+        return False
+    return label == "bac" or code == "5"
+
