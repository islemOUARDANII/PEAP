# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Même DSN que ton parsing-service
POSTGRES_DSN=postgresql://user:password@localhost:5432/matching

# ── Elasticsearch / OpenSearch ──────────────────────────────────────────────
ES_URL=http://localhost:9200
ES_API_KEY=                         # laisser vide si pas d'auth
ES_INDEX_OFFERS=offers
ES_INDEX_CANDIDATES=candidates

# ── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2    # même modèle que le matching engine
EMBEDDING_DIM=384

# ── Sync ────────────────────────────────────────────────────────────────────
SYNC_INTERVAL_SECONDS=60            # fréquence de la sync incrémentale
SYNC_BATCH_SIZE=500

# ── Hybrid scoring ──────────────────────────────────────────────────────────
HYBRID_KEYWORD_WEIGHT=0.4           # poids BM25
HYBRID_VECTOR_WEIGHT=0.6            # poids cosine similarity

# ── API Security ────────────────────────────────────────────────────────────
API_KEY=changeme                    # header X-Api-Key
SERVICE_NAME=search-service
